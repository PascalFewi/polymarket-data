# Polymarket Collector - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================

# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=polymarket
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection pool size (default: 20)
DB_POOL_SIZE=20

# SSL mode: true (default) or false for local development
DB_SSL=true

# =============================================================================
# MARKET SYNC WORKER CONFIGURATION
# =============================================================================

# How often to poll for active markets (milliseconds, default: 60000 = 1 minute)
ACTIVE_POLL_INTERVAL=60000

# How often to poll for closed markets (milliseconds, default: 300000 = 5 minutes)
CLOSED_POLL_INTERVAL=300000

# Minimum 24h volume to include a market (default: 0)
MIN_24H_VOLUME=0

# Maximum 24h volume to include a market (default: Infinity)
# MAX_24H_VOLUME=1000000

# How many days back to fetch closed events (default: 7)
CLOSED_EVENTS_DAYS_BACK=7

# =============================================================================
# ORDERBOOK WORKER CONFIGURATION
# =============================================================================

# Maximum assets per WebSocket connection (default: 500, Polymarket limit)
MAX_ASSETS_PER_SOCKET=500

# How often to check for new tokens in database (milliseconds, default: 30000)
TOKEN_CHECK_INTERVAL=30000

# WebSocket ping interval (milliseconds, default: 10000)
WS_PING_INTERVAL=10000

# Maximum reconnect delay (milliseconds, default: 30000)
MAX_RECONNECT_DELAY=30000

# No-message timeout before reconnect (milliseconds, default: 30000)
NO_MESSAGE_TIMEOUT=30000

# Dashboard update interval (milliseconds, default: 2000)
DASHBOARD_INTERVAL=2000

# =============================================================================
# SHARED CONFIGURATION
# =============================================================================

# Gamma API base URL (default: https://gamma-api.polymarket.com)
# GAMMA_API_URL=https://gamma-api.polymarket.com

# Enable debug logging (default: false)
DEBUG=false
